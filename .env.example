# Copy to .env and fill in real values for local dev.
# In production, all values come from Render env vars (never commit real secrets).
# Hook: pre-commit gitleaks blocks any commit containing real tokens.

# --- Environment ---
ENVIRONMENT=development         # development | production

# --- GHL ---
GHL_API_KEY=                    # GHL private integration token (pit-...)
GHL_LOCATION_ID=                # GHL location/sub-account ID
GHL_WEBHOOK_SECRET=             # Shared secret for GHL webhook verification
GHL_PRIVATE_TOKEN=              # GHL private integration token (used by dashboard)
GHL_CALENDAR_ID=                # GHL calendar ID for appointment booking
GHL_RVM_WORKFLOW_ID=            # GHL workflow ID for RVM cadence

# --- Notion ---
NOTION_TOKEN=                   # Notion integration token (ntn_... or secret_...)
NOTION_LEADS_DB_ID=             # Notion leads database ID

# --- Calendar ---
CALENDAR_SECRET=                # Random secret for iCal feed URL
CALENDAR_EMAIL_DOMAIN=appt.invalid

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./falconconnect.db   # Render uses postgresql+asyncpg://...

# --- Clerk Auth ---
CLERK_PUBLISHABLE_KEY=          # From Clerk dashboard → API Keys (public, ships in bundle)
CLERK_SECRET_KEY=               # From Clerk dashboard → API Keys (server-only)
CLERK_ADMIN_USER_ID=            # Clerk user ID for admin-only operations
# ALLOW_NO_AUTH=true            # DEV ONLY. When true + CLERK_SECRET_KEY empty, auth is bypassed.
                                # Must be unset in production or the app will crash at startup.

# --- Close.com ---
CLOSE_API_KEY=
CLOSE_APPOINTMENT_ACTIVITY_TYPE_ID=actitype_6awVkZoRuXH1FWUd1F97CH
CLOSE_SMS_FROM_NUMBER=
APPOINTMENT_REMINDER_NUMBER=
CLOSE_WEBHOOK_SECRET=           # 64-char Close webhook signing secret

# --- Google Calendar ---
GOOGLE_CALENDAR_ID=primary
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Twilio (Conference Bridge) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+18446813690

# --- Cloudflare Turnstile (bot protection on public lead forms) ---
# In production, leaving this empty will fail-closed (app refuses to boot).
# Set both TURNSTILE_SECRET here and VITE_TURNSTILE_SITEKEY on falconverify.
TURNSTILE_SECRET=

# --- Telegram alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Notion → GHL Sync ---
NOTION_GHL_SYNC_ENABLED=true    # Master on/off switch
NOTION_GHL_SYNC_DRY_RUN=true    # Log-only mode (no GHL writes)
NOTION_GHL_SYNC_AFTER_DATE=2026-03-03
NOTION_GHL_SYNC_INTERVAL=300    # Seconds between polls

# --- FalconLeads research integration ---
FALCONLEADS_BASE=
FALCONLEADS_DB_PATH=
FALCONLEADS_PLAYBOOK_PATH=

# --- Plaid (Phase 2, not yet wired) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox               # sandbox | development | production
